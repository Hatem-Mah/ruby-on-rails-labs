<h1>New Article</h1>

<%= form_with model: @article do |f| %>
  <div>
    <%= f.label :title %>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :body %>
    <%= f.text_area :body %>
  </div>

  <%= f.submit "Save Article" %>
<% end %>

<%= link_to "Back to Articles", articles_path %>
